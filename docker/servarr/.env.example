# User and Group IDs
PUID=1000
PGID=1000
UMASK=002

# Timezone
TZ=America/New_York

# FlareSolverr Configuration
LOG_LEVEL=info
LOG_HTML=false
CAPTCHA_SOLVER=none

# Plex Configuration
PLEX_CLAIM_TOKEN=claim-xxxxxxxxxxxxxxxxxx
PLEX_ADVERTISE_URL=http://your-server-ip:32400
PLEX_NO_AUTH_NETWORKS=192.168.1.0/24
PLEX_BETA_INSTALL=false
PLEX_PURGE_CODECS=false

# qBittorrent Configuration
WEBUI_PORTS=8080/tcp,8080/udp
LIBTORRENT=v1

# Homarr Configuration
SECRET_ENCRYPTION_KEY=your-secret-encryption-key-here

# Port Mappings
SONARR_PORT=8989
RADARR_PORT=7878
PROWLARR_PORT=9696
FLARESOLVERR_PORT=8191
QBITTORRENT_PORT=8080
OVERSEERR_PORT=5055
PLEX_PORT=32400
PORTAINER_PORT=9000
SCRUTINY_PORT=8082
HOMARR_PORT=80

# Scrutiny Device (adjust to your drive)
SCRUTINY_DEVICE=/dev/sda